#!/usr/bin/env ruby
# Generate a three-column comparison page for two drafts.
# Usage: bundle exec ruby _scripts/generate-comparison-html <draft1> <draft2>
# Output: comparison.html in the project root

require 'yaml'
require 'kramdown'
require 'date'

