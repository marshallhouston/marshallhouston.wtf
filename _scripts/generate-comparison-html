  <script>
    function toggleDrawer(side) {
      document.body.classList.toggle(side + '-open');
      const btn = document.getElementById(side === 'left' ? 'leftToggle' : 'rightToggle');
      btn.classList.toggle('active');
    }

    // Inline annotation from drawers
    const hint = document.getElementById('inlineHint');

    document.addEventListener('mouseup', function(e) {
      const sel = window.getSelection();
      const text = sel.toString().trim();
      if (!text) { hint.classList.remove('visible'); return; }

      // Must be inside a drawer
      let node = sel.anchorNode;
      while (node && !node.classList?.contains('drawer-section')) node = node.parentNode;
      if (!node) { hint.classList.remove('visible'); return; }

      const drawer = node.closest('.drawer');
      if (!drawer) return;
      const draft = drawer.dataset.draft || 'unknown';
      const sectionName = node.dataset.section;

      const range = sel.getRangeAt(0);
      const rect = range.getBoundingClientRect();
      hint.style.left = rect.left + (rect.width / 2) - 60 + 'px';
      hint.style.top = (rect.top - 32) + 'px';
      hint.textContent = 'annotating...';
      hint.classList.add('visible');

      // Find matching feedback textarea
      const ta = document.querySelector('.container textarea[data-section="' + sectionName + '"]');
      if (!ta) return;

      const prefix = ta.value.trim() ? ta.value.trimEnd() + '\\n\\n' : '';
      const annotation = '[' + draft + '] instead: "' + text + '"\\ndo: "' + text + '"';
      ta.value = prefix + annotation;

      ta.focus();
      const doStart = ta.value.lastIndexOf('do: "') + 5;
      const doEnd = ta.value.length - 1;
      ta.setSelectionRange(doStart, doEnd);

      hint.textContent = 'added from ' + draft + '!';
      setTimeout(() => hint.classList.remove('visible'), 800);
      sel.removeAllRanges();
    });

    function copyFeedback() {
      const textareas = document.querySelectorAll('.container textarea[data-section]');
      let sections = [];
      textareas.forEach(ta => {
        if (ta.value.trim()) {
          sections.push('## ' + ta.dataset.section + '\\n\\n' + ta.value.trim());
        }
      });
      const title = #{draft1[:title].inspect};
      const output = sections.length
        ? '# comparison feedback: ' + title + '\\n\\n' + sections.join('\\n\\n---\\n\\n')
        : '(no feedback entered)';
      const btn = document.getElementById('copyBtn');
      navigator.clipboard.writeText(output).then(() => {
        btn.textContent = 'copied!';
        btn.classList.add('success');
        setTimeout(() => { btn.textContent = 'copy all feedback as markdown'; btn.classList.remove('success'); }, 2000);
      }).catch(() => {
        const ta = document.createElement('textarea');
        ta.value = output;
        ta.style.cssText = 'position:fixed;opacity:0;';
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
        btn.textContent = 'copied!';
        btn.classList.add('success');
        setTimeout(() => { btn.textContent = 'copy all feedback as markdown'; btn.classList.remove('success'); }, 2000);
      });
    }
  </script>
