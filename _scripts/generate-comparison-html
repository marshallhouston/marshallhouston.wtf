file2 = ARGV[1]
abort "Usage: bundle exec ruby _scripts/generate-comparison-html <draft1> <draft2>" unless file1 && file2
abort "File not found: #{file1}" unless File.exist?(file1)
abort "File not found: #{file2}" unless File.exist?(file2)

def parse_file(path)
  raw = File.read(path)
  title = File.basename(path, '.*').gsub(/[-_]/, ' ')
  body  = raw

  if raw.start_with?('---')
    parts = raw.split(/^---\s*$/, 3)
    if parts.length >= 3
      fm    = YAML.safe_load(parts[1]) rescue {}
      title = fm['title'] || title
      body  = parts[2].strip
    end
  end

  chunks    = body.split(/^## /)
  intro_md  = chunks.shift.strip
  sections  = chunks.map do |chunk|
    lines        = chunk.lines
    section_title = lines.shift.strip
    section_body  = lines.join.strip
    { title: section_title, body: section_body }
  end

  all_sections = []
  all_sections << { title: 'intro / hook', body: intro_md } unless intro_md.empty?
  all_sections.concat(sections)

  { title: title, label: File.basename(path), sections: all_sections }
end

def md_to_html(text)
  # Strip HTML comments (TODOs) for cleaner rendering
  cleaned = text.gsub(/<!--.*?-->/m, '')
  Kramdown::Document.new(cleaned, input: 'GFM').to_html
end

