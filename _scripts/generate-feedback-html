#!/usr/bin/env ruby
# Generate a section-by-section feedback page for any markdown file.
# Usage: bundle exec ruby _scripts/generate-feedback-html <file-path>
# Output: feedback.html in the project root

require 'yaml'
require 'kramdown'
require 'date'

file_path = ARGV[0]
abort "Usage: bundle exec ruby _scripts/generate-feedback-html <file-path>" unless file_path
abort "File not found: #{file_path}" unless File.exist?(file_path)

raw = File.read(file_path)

# Parse frontmatter
title = File.basename(file_path, '.*').gsub(/[-_]/, ' ')
body  = raw

if raw.start_with?('---')
  parts = raw.split(/^---\s*$/, 3)
  if parts.length >= 3
    fm    = YAML.safe_load(parts[1]) rescue {}
    title = fm['title'] || title
    body  = parts[2].strip
  end
end

# Split on H2s — first chunk is intro content (may be empty)
chunks    = body.split(/^## /)
intro_md  = chunks.shift.strip
sections  = chunks.map do |chunk|
  lines        = chunk.lines
  section_title = lines.shift.strip
  section_body  = lines.join.strip
  { title: section_title, body: section_body }
end

all_sections = []
all_sections << { title: 'intro / hook', body: intro_md } unless intro_md.empty?
all_sections.concat(sections)

def md_to_html(text)
  Kramdown::Document.new(text, input: 'GFM').to_html
end

date_str    = Date.today.strftime('%B %-d, %Y').downcase
output_path = File.join(File.dirname(__FILE__), '..', 'feedback.html')

sections_html = all_sections.map do |s|
  content_html = md_to_html(s[:body])
  placeholder  = "notes on: #{s[:title]}"
  <<~HTML
    <div class="post-section">
      <div class="section-label">#{s[:title]}</div>
      <div class="section-body">
        <div class="section-content">#{content_html}</div>
        <div class="feedback-block">
          <div class="feedback-label">feedback</div>
          <textarea data-section="#{s[:title]}" placeholder="#{placeholder}"></textarea>
        </div>
      </div>
    </div>
  HTML
end.join("\n")

html = <<~HTML
  <!DOCTYPE html>
  <html lang="en">
  <head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>feedback: #{title}</title>
  <style>
