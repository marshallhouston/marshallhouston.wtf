---
const links = [
  { label: 'website', url: 'https://marshallhouston.wtf' },
  { label: 'github', url: 'https://github.com/marshallhouston' },
  { label: 'linkedin', url: 'https://linkedin.com/in/marshallhouston' },
  { label: 'rss feed', url: '/feed.xml' },
];
---

<aside class="author-profile">
  <img src="/assets/images/marshall.png" alt="marshall houston" class="avatar" />
  <p class="name">marshall houston</p>
  <p class="bio">writing about the cosmic farmland</p>
  <ul class="links">
    {links.map((l) => (
      <li><a href={l.url}>{l.label}</a></li>
    ))}
  </ul>
</aside>

<style>
  .author-profile {
    margin: 0 0 2rem;
    padding: 1rem;
    background: var(--surface);
    border-radius: 4px;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1rem;
    align-items: center;
  }
  .author-profile .avatar {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    object-fit: cover;
    grid-row: span 3;
  }
  .author-profile .name {
    margin: 0;
    font-weight: 700;
    color: var(--text-strong);
  }
  .author-profile .bio {
    margin: 0;
    color: var(--text-soft);
    font-size: 0.9rem;
  }
  .author-profile .links {
    grid-column: 2;
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    font-size: 0.85rem;
  }
  .author-profile .links a {
    color: var(--text-muted);
  }
  .author-profile .links a:hover {
    color: var(--link-hover);
  }
</style>
