---
// Aa cap-toggle button. Renders the button only.
// Behavior script lives in Layout.astro (once per page).
---

<button class="cap-toggle" type="button" aria-label="switch to standard capitalization" data-tooltip="switch to standard capitalization">Aa</button>

<style>
  .cap-toggle {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text-muted);
    border-radius: 3px;
    padding: 0.15em 0.5em;
    font-size: 0.85em;
    font-family: inherit;
    cursor: pointer;
    line-height: 1;
    margin-left: 0.5em;
    vertical-align: baseline;
    position: relative;
  }
  .cap-toggle:hover { color: var(--link-hover); border-color: var(--link); }
  .cap-toggle[data-tooltip]:hover::after {
    content: attr(data-tooltip);
    position: absolute;
    top: calc(100% + 6px);
    right: 0;
    background: var(--bg-soft, #1a1f2e);
    color: var(--text-strong);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.3em 0.6em;
    font-size: 0.75rem;
    white-space: nowrap;
    z-index: 100;
    pointer-events: none;
  }
  @media (hover: none) {
    .cap-toggle[data-tooltip]:hover::after { display: none; }
  }
</style>
