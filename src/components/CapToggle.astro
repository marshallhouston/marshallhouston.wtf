---
// Aa cap-toggle button. Renders the button only.
// Behavior script lives in Layout.astro (once per page).
---

<button class="cap-toggle" type="button" aria-label="switch to lowerchaos">Aa</button>

<style>
  .cap-toggle {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text-muted);
    border-radius: 3px;
    padding: 0.15em 0.5em;
    font-size: 0.85em;
    font-family: inherit;
    cursor: pointer;
    line-height: 1;
    margin-left: 0.5em;
    vertical-align: baseline;
  }
  .cap-toggle:hover { color: var(--link-hover); border-color: var(--link); }
</style>
