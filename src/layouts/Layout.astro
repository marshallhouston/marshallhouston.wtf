---
import '../styles/global.css';
import { mainNav } from '../data/navigation';
import AuthorProfile from '../components/AuthorProfile.astro';
import CapToggle from '../components/CapToggle.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const SITE_TITLE = 'marshall houston';
const SITE_DESC = 'exploring creativity, ai, and how we write the future together';
const SITE_OG = '/assets/images/og-default.png';

const {
  title = SITE_TITLE,
  description = SITE_DESC,
  ogImage = SITE_OG,
} = Astro.props;

const pageTitle = title === SITE_TITLE ? SITE_TITLE : `${title} · ${SITE_TITLE}`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const ogImageUrl = new URL(ogImage, Astro.site).toString();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/rss+xml" title={SITE_TITLE} href="/feed.xml" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content={SITE_TITLE} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
  </head>
  <body>
    <header class="masthead">
      <div class="inner">
        <a href="/" class="site-title">{SITE_TITLE}</a>
        <nav>
          {mainNav.map((link) => (
            <a href={link.url}>{link.title}</a>
          ))}
          <button class="search-toggle" type="button" aria-label="search" title="search (coming soon)">🔍</button>
          <CapToggle />
        </nav>
      </div>
    </header>
    <div class="layout">
      <div class="sidebar">
        <AuthorProfile />
      </div>
      <main class="content">
        <slot />
      </main>
    </div>
    <footer class="site-footer">
      <p>cosmic farmland · <a href="/feed.xml">rss</a></p>
    </footer>

    <script is:inline>
      (function () {
        const KEY = 'capitalize-pref';
        const saved = sessionStorage.getItem(KEY);
        document.body.dataset.caps = saved === 'off' ? 'off' : 'on';

        function syncAll() {
          const on = document.body.dataset.caps !== 'off';
          const label = on ? 'switch to lowerchaos' : 'switch to standard capitalization';
          document.querySelectorAll('.cap-toggle').forEach(function (b) {
            b.setAttribute('aria-label', label);
            b.setAttribute('title', label);
          });
        }
        syncAll();

        document.addEventListener('click', function (e) {
          const btn = e.target.closest && e.target.closest('.cap-toggle');
          if (!btn) return;
          const on = document.body.dataset.caps !== 'off';
          const next = on ? 'off' : 'on';
          document.body.dataset.caps = next;
          if (next === 'off') sessionStorage.setItem(KEY, 'off');
          else sessionStorage.removeItem(KEY);
          syncAll();
        });
      })();
    </script>
  </body>
</html>
