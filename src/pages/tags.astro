---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import GitHubSlugger from 'github-slugger';

const posts = (await getCollection('posts')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const byTag = new Map<string, typeof posts>();
for (const p of posts) {
  for (const t of p.data.tags) {
    const arr = byTag.get(t) ?? [];
    arr.push(p);
    byTag.set(t, arr);
  }
}

const slugger = new GitHubSlugger();
const tagList = [...byTag.entries()]
  .sort((a, b) => a[0].localeCompare(b[0]))
  .map(([name, items]) => {
    slugger.reset();
    return { name, slug: slugger.slug(name), items };
  });

const fmtDate = (d: Date) =>
  `${String(d.getMonth() + 1).padStart(2, '0')} ${String(d.getDate()).padStart(2, '0')} ${d.getFullYear()}`;
---

<Layout title="tags">
  <h1>tags</h1>

  <div class="tag-cloud">
    {tagList.map((t) => (
      <a href={`#${t.slug}`} class="tag-link">{t.name} ({t.items.length})</a>
    ))}
  </div>

  {tagList.map((t) => (
    <section id={t.slug}>
      <h2>{t.name}</h2>
      <ul>
        {t.items.map((p) => (
          <li>
            <a href={`/${p.data.slug}/`}>{p.data.title}</a>
            <span class="meta"> — {fmtDate(p.data.date)}</span>
          </li>
        ))}
      </ul>
    </section>
  ))}
</Layout>
