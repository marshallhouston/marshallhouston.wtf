---
import Layout from '../layouts/Layout.astro';
import CapToggle from '../components/CapToggle.astro';
import Icon from '../components/Icon.astro';
import { render } from 'astro:content';
import { readMinutes, excerpt, fmtDate, getRoutablePosts } from '../lib/post-utils';

export async function getStaticPaths() {
  const posts = (await getRoutablePosts()).sort(
    (a, b) => a.data.date.valueOf() - b.data.date.valueOf()
  );
  return posts.map((post, i) => ({
    params: { slug: post.data.slug },
    props: {
      post,
      prev: posts[i - 1] ?? null,
      next: posts[i + 1] ?? null,
      all: posts,
    },
  }));
}

const { post, prev, next, all } = Astro.props;
const { Content } = await render(post);

const tagSet = new Set(post.data.tags);
const related = all
  .filter((p) => !p.data.draft && p.data.slug !== post.data.slug && p.data.tags.some((t) => tagSet.has(t)))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const minRead = readMinutes(post.body ?? '');
const postDesc = post.data.description ?? excerpt(post.body ?? '', 200);
const canonicalUrl = new URL(`/${post.data.slug}/`, Astro.site).toString();

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: postDesc,
  url: canonicalUrl,
  datePublished: post.data.date.toISOString(),
  ...(post.data.updated_at ? { dateModified: post.data.updated_at } : {}),
  author: { '@type': 'Person', name: 'Marshall Houston', url: 'https://marshallhouston.wtf' },
  keywords: post.data.tags.join(', '),
};
---

<Layout
  title={post.data.title}
  description={postDesc}
  ogImageAlt={post.data.title}
  customCapToggle={post.data.custom_cap_toggle}
  article={{
    publishedTime: post.data.date,
    modifiedTime: post.data.updated_at,
    tags: post.data.tags,
    jsonLd,
  }}
>
  <article class="post" data-pagefind-body>
    <header>
      <h1>{post.data.title}</h1>
      <p class="meta">
        <Icon name="calendar" />{fmtDate(post.data.date)}
        <span class="sep">·</span>
        <Icon name="clock" />{minRead} min read
        <CapToggle />
      </p>
    </header>
    <Content />
    <footer class="post-footer" data-pagefind-ignore>
      {post.data.updated_at && (
        <p class="meta updated"><Icon name="calendar" />Updated: {post.data.updated_at}</p>
      )}
      {post.data.tags.length > 0 && (
        <p class="post-tags tags">
          <span class="label">Tags:</span>
          {post.data.tags.map((t) => <a href={`/tags/#${t}`}>#{t}</a>)}
        </p>
      )}
    </footer>
  </article>

  {(prev || next) && (
    <nav class="post-nav" data-pagefind-ignore>
      <div class="prev">
        {prev && (
          <>
            <span class="label">previous:</span>
            <a href={`/${prev.data.slug}/`}>{prev.data.title}</a>
          </>
        )}
      </div>
      <div class="next">
        {next && (
          <>
            <span class="label">next:</span>
            <a href={`/${next.data.slug}/`}>{next.data.title}</a>
          </>
        )}
      </div>
    </nav>
  )}

  {related.length > 0 && (
    <section class="related" data-pagefind-ignore>
      <h3 class="archive__subtitle">you may also enjoy</h3>
      <div class="related-grid">
        {related.map((r) => (
          <article class="related-entry">
            <h4 class="related-title">
              <a href={`/${r.data.slug}/`}>{r.data.title}</a>
            </h4>
            <p class="meta"><Icon name="calendar" />{fmtDate(r.data.date)} · <Icon name="clock" />{readMinutes(r.body ?? '')} min</p>
            <p class="excerpt">{excerpt(r.body ?? '', 120)}</p>
          </article>
        ))}
      </div>
    </section>
  )}
</Layout>
