{
	admin off
	auto_https off
	persist_config off
}

:{$PORT:8080} {
	root * /srv
	encode zstd gzip

	# Strip trailing slash on non-root paths (canonical = no slash).
	@trailingSlash {
		path_regexp slash ^(.+)/$
	}
	redir @trailingSlash {re.slash.1} 308

	# Astro emits pretty URLs as /path.html — let Caddy find them.
	try_files {path} {path}.html {path}/index.html =404

	file_server

	header {
		# Conservative defaults; tighten later if we care.
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	log {
		output stdout
		format console
	}
}
