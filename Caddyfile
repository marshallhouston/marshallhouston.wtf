{
	admin off
	auto_https off
	persist_config off
}

:{$PORT:8080} {
	root * /srv
	encode zstd gzip

	# Jekyll emits pretty URLs as /path/index.html — let Caddy find them.
	try_files {path} {path}/ {path}.html =404

	file_server

	header {
		# Conservative defaults; tighten later if we care.
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	log {
		output stdout
		format console
	}
}
