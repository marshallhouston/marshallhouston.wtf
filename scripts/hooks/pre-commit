#!/bin/sh
# Pre-commit checks for the Astro site.
#
# 1. New/modified posts in src/content/posts/ must declare tags.
# 2. When site code (src/, public/, astro config, tests) is staged, run the
#    Playwright suite. The suite auto-starts `astro preview` via webServer,
#    so no separate dev server is required.

set -e

STAGED=$(git diff --cached --name-only --diff-filter=ACM)

# 1. Tag presence on posts
STAGED_POSTS=$(echo "$STAGED" | grep -E '^src/content/posts/.*\.md$' || true)
if [ -n "$STAGED_POSTS" ]; then
  MISSING=""
  for post in $STAGED_POSTS; do
    if grep -q '^draft: true' "$post" 2>/dev/null; then continue; fi
    if ! grep -q '^tags:' "$post" 2>/dev/null; then
      MISSING="$MISSING\n  ✗ $post"
    fi
  done
  if [ -n "$MISSING" ]; then
    printf "\nposts missing \`tags:\` frontmatter:%b\n\n  add tags: [tag1, tag2]\n\n" "$MISSING"
    exit 1
  fi
fi

# 2. Playwright suite when site code changes
RELEVANT='^(src/|public/|astro\.config\.|package(-lock)?\.json|tests/|playwright\.config\.|src/content/posts/.*\.md)'
CHANGED=$(echo "$STAGED" | grep -E "$RELEVANT" || true)

if [ -z "$CHANGED" ]; then
  exit 0
fi

echo "site code changed — running Playwright suite (auto-starts preview)..."

# Build first so site-properties.spec can read dist/sitemap.xml
npm run build >/dev/null
npx playwright test
