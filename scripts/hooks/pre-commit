#!/bin/sh

HOOKS_DIR="$(dirname "$0")"

# 1. Check new posts for proper nouns missing from capitalize config (warn only)
bash "$HOOKS_DIR/check-capitalize-config.sh"

# 2. Block "whitelist"/"blacklist" in staged content (blocks commit)
bash "$HOOKS_DIR/check-inclusive-language.sh" || exit 1

# 3. Build site and validate: layouts, links, theme rendering, structural consistency (blocks commit)
bash "$HOOKS_DIR/check-site-health.sh" || exit 1

# 3. Run Playwright tests when relevant files are changed
RELEVANT_FILES="assets/js/capitalize-toggle.js|_includes/masthead.html|_includes/head/custom.html|_layouts/.*|_includes/.*|assets/css/main.scss|_config.yml|tests/.*\.spec\.js|_posts/.*\.md"

CHANGED=$(git diff --cached --name-only | grep -E "$RELEVANT_FILES")

if [ -z "$CHANGED" ]; then
  exit 0
fi

echo "layout/component files changed — running Playwright tests..."

# check if Jekyll is running
if ! curl -s -o /dev/null -w "" http://localhost:4000/ 2>/dev/null; then
  echo "⚠ Jekyll server not running at localhost:4000 — skipping Playwright tests"
  echo "  Start with: bundle exec jekyll serve"
  exit 0
fi

npx playwright test tests/
EXIT_CODE=$?

if [ $EXIT_CODE -ne 0 ]; then
  echo ""
  echo "✗ Playwright tests failed — commit blocked"
  echo "  Fix the issues and try again"
  exit 1
fi

echo "✓ All Playwright tests passed"
